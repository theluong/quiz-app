{
  "builds": [
    {
      "src": "api/categories.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/questions.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/submit.js",
      "use": "@vercel/node"
    },
    {
      "src": "frontend/dist",
      "use": "static"
    }
  ],
  "routes": [
    {
      "src": "/api/categories",
      "dest": "/api/categories.js"
    },
    {
      "src": "/api/questions",
      "dest": "/api/questions.js"
    },
    {
      "src": "/api/submit",
      "dest": "/api/submit.js"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}